APP_NAME=week-10-observability-api
APP_ENV=development
LOG_LEVEL=INFO
LOG_DB_PATH=logs/app_logs.sqlite3
# Optional. If set, GET /admin/logs requires header X-Log-Viewer-Key.
LOG_VIEWER_API_KEY=

# Use "*" for local demo. In production, set a comma-separated allowlist if a frontend exists.
CORS_ORIGINS=*

RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_WRITE=10/minute
RATE_LIMIT_EXTERNAL=5/minute

# Normal demo value: https://httpbin.org/status/200
# Failure demo value option: https://httpbin.org/status/503
EXTERNAL_SERVICE_URL=https://httpbin.org/status/200

# Set to true locally or in deploy dashboard, then restart the app to force external failures.
EXTERNAL_FAILURE_MODE=false
CIRCUIT_FAIL_MAX=3
CIRCUIT_RESET_TIMEOUT_SECONDS=30
